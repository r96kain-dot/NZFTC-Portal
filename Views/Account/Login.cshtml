@{
    ViewData["Title"] = "Login";
    Layout = null;

    // Checks whether the page was loaded with a login error.
    var hasLoginError = TempData["LoginError"] != null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Meta setup -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Page title -->
    <title>Login - NZFTC Portal</title>

    <!-- Login page CSS -->
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />

    <style>
        /* Keeps the forgot password row positioned for the popup. */
        .form-link-row {
            position: relative;
        }

        /* Shows a small popup close to the forgot password link. */
        .forgot-password-popup {
            position: absolute;
            top: 100%;
            right: 0;
            margin-top: 8px;
            background-color: #111111;
            color: #ffffff;
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 12px;
            line-height: 1.3;
            white-space: nowrap;
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
            z-index: 3000;
            display: none;
        }

            /* Shows the popup when the helper class is added. */
            .forgot-password-popup.show {
                display: block;
            }

        /* Styles the login error as a small inline message. */
        .login-error-message {
            margin-top: 4px;
            margin-bottom: 8px;
            padding: 10px 12px;
            border: 1px solid #f0b7b7;
            border-radius: 8px;
            background-color: #fff4f4;
            color: #b42318;
            font-size: 13px;
            line-height: 1.35;
        }

        line-height: 1.35;
        }
    </style>
</head>
<body>
    <!-- Login page wrapper -->
    <main class="login-page">
        <!-- Login card -->
        <section class="login-card">
            <!-- Logo -->
            <div class="login-logo">
                <img src="~/images/default_logo.png" alt="NZFTC Portal logo" />
            </div>

            <!-- Login form -->
            <form class="login-form" method="post" asp-controller="Account" asp-action="Login">
                <!-- Email field -->
                <div class="form-group">
                    <label for="email">Email</label>
                    <input id="email"
                           name="email"
                           type="email"
                           placeholder="Enter your email" />
                </div>

                <!-- Password field -->
                <div class="form-group">
                    <label for="password">Password</label>
                    <input id="password"
                           name="password"
                           type="password"
                           placeholder="Enter your password" />
                </div>

                <!-- Forgot password link and popup -->
                <div class="form-link-row">
                    <a href="#" class="forgot-password" id="forgotPasswordLink">Forgot Password?</a>

                    <div class="forgot-password-popup" id="forgotPasswordPopup">
                        Instructions have been sent to your email.
                    </div>
                </div>

                <!-- Login error message -->
                @if (hasLoginError)
                {
                    <div class="login-error-message">
                        @TempData["LoginError"]
                    </div>
                }

                <!-- Role selection -->
                <div class="role-section">
                    <p class="role-heading">Sign in as</p>

                    <!-- Employee role -->
                    <label class="role-option" for="employeeRole">
                        <input id="employeeRole"
                               name="role"
                               type="radio"
                               value="Employee" />

                        <span class="role-custom-radio"></span>

                        <span class="role-text-group">
                            <span class="role-title">Employee</span>
                            <span class="role-description">
                                Access your personal dashboard, leave requests, and payroll details.
                            </span>
                        </span>
                    </label>

                    <!-- Administrator role -->
                    <label class="role-option" for="adminRole">
                        <input id="adminRole"
                               name="role"
                               type="radio"
                               value="Administrator" />

                        <span class="role-custom-radio"></span>

                        <span class="role-text-group">
                            <span class="role-title">Administrator</span>
                            <span class="role-description">
                                Manage employee records, approvals, payroll, and system settings.
                            </span>
                        </span>
                    </label>
                </div>

                <!-- Sign in button -->
                <button type="submit" class="sign-in-btn">Sign In</button>
            </form>
        </section>
    </main>

    <script>
        const forgotPasswordLink = document.getElementById("forgotPasswordLink");
        const forgotPasswordPopup = document.getElementById("forgotPasswordPopup");
        let forgotPasswordPopupTimer;

        // Shows a small popup beside the forgot password link when clicked.
        forgotPasswordLink.addEventListener("click", function (event) {
            event.preventDefault();

            // Resets the popup timer if the link is clicked again.
            clearTimeout(forgotPasswordPopupTimer);

            // Displays the popup beside the forgot password link.
            forgotPasswordPopup.classList.add("show");

            // Hides the popup after a short delay.
            forgotPasswordPopupTimer = setTimeout(function () {
                forgotPasswordPopup.classList.remove("show");
            }, 2200);
        });
    </script>
</body>
</html>