@{
    ViewData["Title"] = "Employee Leave";
    Layout = "~/Views/Shared/_PortalLayout.cshtml";
}

@section Styles {
    <!-- Employee leave CSS -->
    <link rel="stylesheet" href="~/css/employee-leave.css" asp-append-version="true" />
}

<!-- Leave page -->
<section class="leave-page">
    <!-- Page heading row -->
    <div class="leave-page-top">
        <!-- Page heading -->
        <div class="leave-heading">
            <h1>My Leave</h1>
            <p>Request leave and view your history</p>
        </div>

        <!-- Request leave button -->
        <div class="leave-top-action">
            <button type="button" class="request-leave-button" id="openLeaveModal">+ Request Leave</button>
        </div>
    </div>

    <!-- Leave history card -->
    <section class="leave-card">
        <!-- Section heading -->
        <div class="leave-card-heading">
            <h2>Leave History</h2>
            <p>Your leave requests and their status</p>
        </div>

        <!-- Leave table -->
        <div class="leave-table-wrapper">
            <table class="leave-table">
                <thead>
                    <tr>
                        <th>Request ID</th>
                        <th>Type</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Days</th>
                        <th>Status</th>
                        <th>Reason</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Placeholder row -->
                    <tr>
                        <td>LV-001</td>
                        <td>Annual Leave</td>
                        <td>12/04/2026</td>
                        <td>14/04/2026</td>
                        <td>3</td>
                        <td>
                            <span class="status-badge pending-status">Pending</span>
                        </td>
                        <td>Family trip</td>
                    </tr>

                    <!-- Placeholder row -->
                    <tr>
                        <td>LV-002</td>
                        <td>Sick Leave</td>
                        <td>22/03/2026</td>
                        <td>22/03/2026</td>
                        <td>1</td>
                        <td>
                            <span class="status-badge approved-status">Approved</span>
                        </td>
                        <td>Medical appointment</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
</section>

<!-- Leave request modal -->
<div class="leave-modal-overlay" id="leaveModal">
    <div class="leave-modal" role="dialog" aria-modal="true" aria-labelledby="leaveModalTitle">
        <!-- Modal close -->
        <button type="button" class="leave-modal-close" id="closeLeaveModal" aria-label="Close leave request modal">
            x
        </button>

        <!-- Modal heading -->
        <div class="leave-modal-header">
            <h2 id="leaveModalTitle">Request Leave</h2>
            <p>Submit a new leave request for approval</p>
        </div>

        <!-- Modal form -->
        <form class="leave-modal-form" id="leaveRequestForm">
            <!-- Leave type -->
            <div class="leave-form-group">
                <label for="leaveType">Leave Type</label>
                <select id="leaveType" name="leaveType">
                    <option value="">Annual Leave</option>
                    <option value="annual">Annual Leave</option>
                    <option value="sick">Sick Leave</option>
                    <option value="bereavement">Bereavement Leave</option>
                    <option value="unpaid">Unpaid Leave</option>
                </select>
            </div>

            <!-- Date row -->
            <div class="leave-form-row">
                <div class="leave-form-group">
                    <label for="startDate">Start Date</label>
                    <input type="text" id="startDate" name="startDate" placeholder="dd/mm/yyyy" />
                </div>

                <div class="leave-form-group">
                    <label for="endDate">End Date</label>
                    <input type="text" id="endDate" name="endDate" placeholder="dd/mm/yyyy" />
                </div>
            </div>

            <!-- Reason -->
            <div class="leave-form-group">
                <label for="leaveReason">Reason</label>
                <textarea id="leaveReason" name="leaveReason" rows="5" placeholder="Brief description of your leave request"></textarea>
            </div>

            <!-- Modal actions -->
            <div class="leave-modal-actions">
                <button type="button" class="leave-cancel-button" id="cancelLeaveModal">Cancel</button>
                <button type="submit" class="leave-submit-button">Submit Request</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const leaveModal = document.getElementById("leaveModal");
        const openLeaveModal = document.getElementById("openLeaveModal");
        const closeLeaveModal = document.getElementById("closeLeaveModal");
        const cancelLeaveModal = document.getElementById("cancelLeaveModal");
        const leaveRequestForm = document.getElementById("leaveRequestForm");

        function showLeaveModal() {
            leaveModal.classList.add("show");
            document.body.classList.add("leave-modal-open");
        }

        function hideLeaveModal() {
            leaveModal.classList.remove("show");
            document.body.classList.remove("leave-modal-open");
        }

        openLeaveModal.addEventListener("click", showLeaveModal);
        closeLeaveModal.addEventListener("click", hideLeaveModal);
        cancelLeaveModal.addEventListener("click", hideLeaveModal);

        leaveModal.addEventListener("click", function (event) {
            if (event.target === leaveModal) {
                hideLeaveModal();
            }
        });

        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape" && leaveModal.classList.contains("show")) {
                hideLeaveModal();
            }
        });

        leaveRequestForm.addEventListener("submit", function (event) {
            event.preventDefault();

            // Stub for future leave request function
            console.log("Submit Request clicked");
        });
    </script>
}