@{
    ViewData["Title"] = "Case Management";
    Layout = "~/Views/Shared/_PortalLayout.cshtml";
}

@section Styles {
    <!-- Admin cases CSS -->
    <link rel="stylesheet" href="~/css/admin-cases.css" asp-append-version="true" />
}

<!-- Admin cases page -->
<section class="admin-cases-page">
    <!-- Page heading -->
    <div class="admin-cases-heading">
        <h1>Cases Management</h1>
        <p>Review and manage employee grievances and resignations</p>
    </div>

    <!-- Cases card -->
    <section class="cases-card">
        <!-- Card heading -->
        <div class="cases-card-heading">
            <h2>Cases Management</h2>
            <p>All pending cases in the organization</p>
        </div>

        <!-- Cases table -->
        <div class="cases-table-wrapper">
            <table class="cases-table">
                <thead>
                    <tr>
                        <th>Case ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Position</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>--</td>
                        <td>--</td>
                        <td>--</td>
                        <td>--</td>
                        <td>--</td>
                        <td>--</td>
                        <td>
                            <span class="case-status-badge pending-status">Pending</span>
                        </td>
                        <td>
                            <button type="button" class="view-button" id="openCaseModal">View</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
</section>

<!-- Case details modal -->
<div class="case-modal-overlay" id="caseModal">
    <div class="case-modal" role="dialog" aria-modal="true" aria-labelledby="caseModalTitle">
        <!-- Modal close -->
        <button type="button" class="case-modal-close" id="closeCaseModal" aria-label="Close case details modal">
            x
        </button>

        <!-- Modal heading -->
        <div class="case-modal-header">
            <h2 id="caseModalTitle">Case Details</h2>
            <p>--</p>
        </div>

        <!-- Modal form -->
        <form class="case-modal-form" id="caseUpdateForm">
            <div class="case-form-group">
                <label for="caseEmployee">Employee</label>
                <input type="text" id="caseEmployee" value="--" readonly />
            </div>

            <div class="case-form-group">
                <label for="caseSubmittedDate">Submitted Date</label>
                <input type="text" id="caseSubmittedDate" value="--" readonly />
            </div>

            <div class="case-form-group">
                <label for="caseSubject">Subject</label>
                <input type="text" id="caseSubject" value="--" readonly />
            </div>

            <div class="case-form-group">
                <label for="caseDescription">Description</label>
                <textarea id="caseDescription" rows="4" readonly>--</textarea>
            </div>

            <div class="case-form-group">
                <label for="caseStatusUpdate">Update Case Status</label>
                <select id="caseStatusUpdate" name="caseStatusUpdate">
                    <option value="">--</option>
                </select>
            </div>

            <div class="case-form-group">
                <label for="caseNotes">Update Case</label>
                <textarea id="caseNotes" name="caseNotes" rows="3" placeholder="--"></textarea>
            </div>

            <div class="case-modal-actions">
                <button type="button" class="case-cancel-button" id="cancelCaseModal">Cancel</button>
                <button type="submit" class="case-update-button">Update Case</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const caseModal = document.getElementById("caseModal");
        const openCaseModal = document.getElementById("openCaseModal");
        const closeCaseModal = document.getElementById("closeCaseModal");
        const cancelCaseModal = document.getElementById("cancelCaseModal");
        const caseUpdateForm = document.getElementById("caseUpdateForm");

        function showCaseModal() {
            caseModal.classList.add("show");
            document.body.classList.add("case-modal-open");
        }

        function hideCaseModal() {
            caseModal.classList.remove("show");
            document.body.classList.remove("case-modal-open");
        }

        openCaseModal.addEventListener("click", showCaseModal);
        closeCaseModal.addEventListener("click", hideCaseModal);
        cancelCaseModal.addEventListener("click", hideCaseModal);

        caseModal.addEventListener("click", function (event) {
            if (event.target === caseModal) {
                hideCaseModal();
            }
        });

        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape" && caseModal.classList.contains("show")) {
                hideCaseModal();
            }
        });

        caseUpdateForm.addEventListener("submit", function (event) {
            event.preventDefault();

            // Stub for future case update function
            console.log("Update Case clicked");
        });
    </script>
}