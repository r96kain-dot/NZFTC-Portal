@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_PortalLayout.cshtml";
}

@section Styles {
    <!-- Admin dashboard CSS -->
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
}

<!-- Admin dashboard page -->
<section class="admin-dashboard-page">
    <!-- Page heading -->
    <div class="admin-dashboard-heading">
        <h1>Admin Dashboard</h1>
        <p>Manage employees and approve requests</p>
    </div>

    <!-- Stats row -->
    <section class="admin-stats-grid">
        <!-- Pending leave approvals -->
        <article class="admin-stat-card">
            <div class="admin-stat-card-heading">
                <h2>Pending Leave Approvals</h2>
            </div>

            <div class="admin-stat-content">
                <div class="admin-stat-value">--</div>

                <span class="admin-stat-icon warning-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" />
                        <path d="M12 7V12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        <path d="M12 12L15 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </span>
            </div>

            <div class="admin-stat-action">
                <a href="#" class="admin-card-button">View pending requests</a>
            </div>
        </article>

        <!-- Employee count -->
        <article class="admin-stat-card">
            <div class="admin-stat-card-heading">
                <h2>Employee Count</h2>
            </div>

            <div class="admin-stat-content">
                <div class="admin-stat-value">--</div>

                <span class="admin-stat-icon people-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="9" cy="9" r="3" stroke="currentColor" stroke-width="2" />
                        <circle cx="17" cy="11" r="2.5" stroke="currentColor" stroke-width="2" />
                        <path d="M4.5 19C4.5 16.5 6.8 15 9.5 15C12.2 15 14.5 16.5 14.5 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        <path d="M14.5 18C14.9 16.4 16.4 15.5 18 15.5C19.8 15.5 21 16.5 21 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </span>
            </div>

            <div class="admin-stat-action">
                <a href="#" class="admin-card-button">Manage employees</a>
            </div>
        </article>

        <!-- Open grievances -->
        <article class="admin-stat-card">
            <div class="admin-stat-card-heading">
                <h2>Open Grievances</h2>
            </div>

            <div class="admin-stat-content">
                <div class="admin-stat-value">--</div>

                <span class="admin-stat-icon alert-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" />
                        <path d="M12 7.5V13" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        <circle cx="12" cy="16.5" r="1.2" fill="currentColor" />
                    </svg>
                </span>
            </div>

            <div class="admin-stat-action">
                <a href="#" class="admin-card-button">Review cases</a>
            </div>
        </article>
    </section>

    <!-- Recent leave requests -->
    <section class="admin-requests-card">
        <div class="admin-requests-heading">
            <h2>Recent Leave Requests</h2>
            <p>Requires your approval</p>
        </div>

        <div class="admin-request-list">
            <!-- Request row -->
            <article class="admin-request-row">
                <div class="admin-request-text">
                    <h3>Employee Name</h3>
                    <p>Leave type · Dates coming soon</p>
                </div>

                <div class="admin-request-actions">
                    <span class="request-status-badge pending-status">Pending</span>
                    <a href="#" class="review-button">Review</a>
                </div>
            </article>

            <!-- Request row -->
            <article class="admin-request-row">
                <div class="admin-request-text">
                    <h3>Employee Name</h3>
                    <p>Leave type · Dates coming soon</p>
                </div>

                <div class="admin-request-actions">
                    <span class="request-status-badge pending-status">Pending</span>
                    <a href="#" class="review-button">Review</a>
                </div>
            </article>
        </div>
    </section>
</section>